# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────
# NE PAS committer ce fichier sur GitHub → déjà dans .gitignore
# Sur Streamlit Cloud : Settings → Secrets → coller ce contenu
# ─────────────────────────────────────────────────────────────────

OANDA_API_KEY     = "votre-clé-ici"
OANDA_ACCOUNT_ID  = "votre-account-id"
OANDA_ENVIRONMENT = "practice"   # "practice" ou "live"
